# ─────────────────────────────────────────
# Python
# ─────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd

# Distribution / packaging
dist/
build/
*.egg-info/
*.egg
.eggs/
site-packages/

# Unit test / coverage
.pytest_cache/
.coverage
htmlcov/
.tox/
nosetests.xml
coverage.xml
*.cover

# ─────────────────────────────────────────
# Virtual Environments
# ─────────────────────────────────────────
venv/
.venv/
env/
.env/
automation_env/
fast_env/
premium_env/

# ─────────────────────────────────────────
# Playwright
# ─────────────────────────────────────────
# Playwright browser binaries (downloaded at runtime)
playwright-browsers/
ms-playwright/
test-results/
playwright-report/

# Screenshots — only ignore standalone debug shots
# The screenshot_before/ and screenshot_after/ folders (including all images) are tracked
debug_shot.png

# ─────────────────────────────────────────
# Chrome / Browser Profiles & Automation State
# ─────────────────────────────────────────
automation_profile/
automation_context/
temp_profile/

# ─────────────────────────────────────────
# Logs & Runtime Output
# ─────────────────────────────────────────
*.log
output.log
logs/
# Keep analytics log
!analytics.log

# ─────────────────────────────────────────
# Analytics / Data Files
# ─────────────────────────────────────────
# Keep analytics files (useful for tracking run history)
!analytics.json
!analytics_test.json

# ─────────────────────────────────────────
# Input Data
# ─────────────────────────────────────────
*.xlsx
*.xls
# Allow the main links input file
!links.csv

# ─────────────────────────────────────────
# Environment Variables & Secrets
# ─────────────────────────────────────────
.env
.env.*
*.env
secrets.json
config.local.*

# ─────────────────────────────────────────
# IDE / Editor
# ─────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ─────────────────────────────────────────
# Windows
# ─────────────────────────────────────────
desktop.ini
ehthumbs.db
$RECYCLE.BIN/
